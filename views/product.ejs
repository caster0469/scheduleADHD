<%-
  include("partials/layout", {
    title: product?.name ? `${product.name} | YANREPHOUSE` : "YANREPHOUSE",
    user,
    csrf,
    body: `
      <a class="back" href="/">← 戻る</a>
      <div class="product">
        <div class="product-media">
          ${product.image_url ? `<img src="${product.image_url}" alt="${(product.name||"").replaceAll('"','&quot;')}" />` : `<div class="product-placeholder">No image</div>`}
        </div>
        <div class="product-info">
          <h1>${product.name}</h1>
          <div class="price">¥${Number(product.price||0).toLocaleString()}</div>
          <p class="muted">${String(product.description||"").replaceAll("<","&lt;").replaceAll("\n","<br>")}</p>
        </div>
      </div>
    `
  })
%>
