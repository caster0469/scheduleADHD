<% 
  const isEdit = mode === "edit";
  const p = product || {};
%>
<%-
  include("../partials/layout", {
    title: (isEdit ? "商品編集" : "商品追加") + " | YANREPHOUSE",
    user,
    csrf,
    body: `
      <section class="section narrow">
        <div class="row">
          <h1>${isEdit ? "商品編集" : "商品追加"}</h1>
          <a class="btn ghost" href="/admin/products">戻る</a>
        </div>

        ${error ? `<div class="alert">${String(error).replaceAll("<","&lt;")}</div>` : ``}

        <form method="post" enctype="multipart/form-data" action="${isEdit ? `/admin/products/${p.id}/edit` : `/admin/products/new`}" class="form">
          <input type="hidden" name="_csrf" value="${csrf}">
          <label>商品名
            <input name="name" value="${(p.name||"").replaceAll('"','&quot;')}" required />
          </label>

          <label>価格（円）
            <input name="price" type="number" min="0" value="${Number(p.price||0)}" />
          </label>

          <label>説明（改行OK）
            <textarea name="description" rows="6">${(p.description||"")}</textarea>
          </label>

          <div class="split">
            <label>画像URL（任意）
              <input name="image_url" placeholder="https://..." value="${(p.image_url||"").startsWith("/public/uploads/") ? "" : (p.image_url||"").replaceAll('"','&quot;')}" />
            </label>

            <label>画像アップロード（任意・2MBまで）
              <input name="image_file" type="file" accept="image/*" />
            </label>
          </div>

          ${isEdit ? `
            <label class="checkbox">
              <input type="checkbox" name="keep_image" checked />
              <span>今の画像を保持（外すとURL/アップロードで置き換え or 空で削除）</span>
            </label>
            ${p.image_url ? `<div class="preview"><img src="${p.image_url}" alt="preview"></div>` : ``}
          ` : ``}

          <button class="btn" type="submit">${isEdit ? "更新" : "作成"}</button>
        </form>
      </section>
    `
  })
%>
